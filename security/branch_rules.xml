<odoo>

    <record id="rule_picking_type_branch" model="ir.rule">
        <field name="name">Picking Type Branch Rule</field>
        <field name="model_id" ref="stock.model_stock_picking_type"/>
        <field name="domain_force">[('x_branch_id','=', user.x_branch_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_picking_branch" model="ir.rule">
        <field name="name">Picking Branch Rule</field>
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="domain_force">[('x_branch_id','=', user.x_branch_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

</odoo>
